# ── Flask ─────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-something-random
FLASK_ENV=development

# ── AI (OpenRouter) ───────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# ── Google Drive ──────────────────────────────────────────────────
# Share your Drive folder as "Anyone with the link" (view only), then paste the folder ID.
# Open the folder in Drive → copy the ID from the URL:
#   https://drive.google.com/drive/folders/<FOLDER_ID_HERE>
GOOGLE_DRIVE_FOLDER_ID=

# Optional: local directory where Drive files are downloaded before ingestion.
# Defaults to  data/  inside the project root.
DRIVE_DOWNLOAD_DIR=data